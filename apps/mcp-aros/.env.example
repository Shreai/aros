# AROS MCP facade
PORT=5468

# Existing AROS API, used as the policy and data authority.
AROS_API_BASE=https://app.aros.live

# Public URL used in metadata responses after deployment.
AROS_MCP_PUBLIC_BASE_URL=https://mcp.shre.ai
AROS_MCP_RESOURCE=https://mcp.shre.ai/aros
AROS_OPERATOR_MCP_URL=https://mcp.shre.ai/aros/operator
AROS_CUSTOMER_MCP_URL=https://mcp.shre.ai/aros/customer
# Operator MCP endpoint: https://mcp.shre.ai/aros/operator
# Customer MCP endpoint: https://mcp.shre.ai/aros/customer

# OAuth issuer for ChatGPT/Claude marketplace connections.
AROS_OAUTH_ISSUER=https://id.shre.ai
AROS_OAUTH_AUDIENCE=https://mcp.shre.ai/aros
AROS_OPERATOR_REQUIRED_SCOPES=openid
AROS_REQUIRE_OPERATOR_SCOPE=true

# Optional during Claude Code local testing, if Zitadel emits the client ID as
# aud instead of the resource indicator:
# AROS_OAUTH_AUDIENCE=https://mcp.shre.ai/aros,382142423410671619

# Local-only synthetic data mode. Keep false in production.
AROS_MCP_DEMO_MODE=false
