{
  "$schema": "./mesh.schema.json",
  "_doc": "Minimal AROS service mesh metadata for shre-sdk heartbeat resolution in the AROS deploy root.",
  "_tailnet": {
    "suffix": "taile6b7d4.ts.net",
    "account": "nirp86@"
  },
  "nodes": {
    "aros-vps": {
      "hostname": "shre",
      "tailscaleIp": "100.107.37.98",
