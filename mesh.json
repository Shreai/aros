      "hardware": "Hostinger VPS",
      "os": "linux",
      "role": "edge",
      "description": "Public AROS production origin and platform services.",
      "services": [
        "aros-platform",
        "shre-router",
        "mib007",
        "shre-model-gateway",
        "shre-secrets"
      ],
      "priority": "P0",
      "keepAlive": true
    },
    "shadow": {
      "hostname": "shadow",
      "tailscaleIp": "100.86.194.36",
